# Caminho-base com barra no início e no final.
# GitHub Pages: /almeida-castro-advocacia/
# Domínio próprio, Netlify ou Vercel: /
VITE_BASE_PATH=/almeida-castro-advocacia/

# Segurança contra indexação acidental de dados demonstrativos.
VITE_IS_DEMO=true
VITE_ALLOW_INDEXING=false
